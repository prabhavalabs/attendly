{
  // Admin portal on Cloudflare Workers static assets.
  // Build first: VITE_API_URL=https://attendly-api.prabhavalabs.com pnpm --filter @tuition/admin build
  // Deploy:      npx wrangler deploy -c apps/admin/wrangler.jsonc
  "name": "attendly-admin",
  "compatibility_date": "2026-07-01",
  "routes": [{ "pattern": "attendly.prabhavalabs.com", "custom_domain": true }],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
