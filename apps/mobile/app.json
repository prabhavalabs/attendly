{
  "expo": {
    "name": "attendly",
    "slug": "attendly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "attendly",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.attendly.doorcheckin",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "attendly uses the camera to scan student QR cards for door check-in."
      }
    },
    "android": {
      "package": "com.attendly.doorcheckin",
      "adaptiveIcon": {
        "backgroundColor": "#0a4f47",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.NFC"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "attendly",
      "shortName": "attendly",
      "themeColor": "#0e766a",
      "backgroundColor": "#ffffff",
      "display": "standalone",
      "startUrl": "/",
      "lang": "en"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0e766a",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 120
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "attendly uses the camera to scan student QR cards for door check-in."
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "expo-dev-client",
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "attendly reads student NFC cards for door check-in.",
          "selectIdentifiers": [],
          "includeNdefEntitlement": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
