# Copy to .env (gitignored). Expo auto-loads EXPO_PUBLIC_* at bundle time.
#
# Easiest path — point the app at the deployed API (works on an emulator AND a
# physical device with no extra setup; native apps don't need CORS):
EXPO_PUBLIC_API_BASE_URL=https://attendly-api.junioremployer.com

# --- Local backend instead (pnpm --filter @tuition/api dev on :8787) ---
# Android emulator → the host machine is 10.0.2.2, not localhost:
#   EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8787
# Physical device on the same Wi-Fi → your machine's LAN IP
# (and add that origin to the API's CORS_ORIGINS only for the web/PWA target):
#   EXPO_PUBLIC_API_BASE_URL=http://192.168.1.x:8787
