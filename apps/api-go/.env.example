# Copy to .env (gitignored) for local runs. In production set real values.
ADDR=:8787
DB_PATH=./data/attendly.db
ASSETS_DIR=./data/assets

# Must match the values used to issue existing tokens / encrypt stored data.
JWT_SECRET=
ENCRYPTION_KEY=

# Google Calendar OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: allows re-running POST /api/setup after the first user exists.
SETUP_TOKEN=

# Comma-separated allowed browser origins (admin portal, etc.)
CORS_ORIGINS=http://localhost:5173
